load("//defs:package.bzl", "package")

# =============================================================================
# CMake - Cross-platform build system
# =============================================================================
# CMake uses its own bootstrap script, not autotools configure.
# skip_configure + pre_build_cmds runs bootstrap in the copied source tree,
# then the normal make phase builds from the generated Makefile.

package(
    build_rule = "autotools",
    name = "cmake",
    version = "4.2.0",
    url = "https://github.com/Kitware/CMake/releases/download/v4.2.0/cmake-4.2.0.tar.gz",
    sha256 = "4104e94657d247c811cb29985405a360b78130b5d51e7f6daceb2447830bd579",
    description = "Cross-platform, open-source build system",
    homepage = "https://cmake.org/",
    license = "BSD-3-Clause",
    skip_configure = True,
    pre_build_cmds = [
        # CMake bootstrap respects CC/CXX from environment.  GCC specs
        # inject padded interpreter + RPATH unconditionally at link time,
        # so no CFLAGS/LDFLAGS needed.  Disable ccmake (curses GUI) to
        # avoid NCURSES_BOOL/std::function conflict with GCC 15.
        # Patch bundled curl to disable libidn2 (hardcoded ON, -D flag
        # cannot override the set() call in cmcurl/CMakeLists.txt).
        "sed -i 's/^set(USE_LIBIDN2 ON)/set(USE_LIBIDN2 OFF)/' Utilities/cmcurl/CMakeLists.txt",
        "./bootstrap --prefix=/usr --parallel=$(nproc) --no-qt-gui -- -DCMAKE_USE_OPENSSL=OFF -DBUILD_CursesDialog=OFF",
    ],
    deps = [],
)
