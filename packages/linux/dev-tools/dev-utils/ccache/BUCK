load("//defs:package.bzl", "package")

# ccache is a CMake-based project
package(
    build_rule = "cmake",
    name = "ccache",
    version = "4.13.1",
    url = "https://github.com/ccache/ccache/releases/download/v4.13.1/ccache-4.13.1.tar.xz",
    sha256 = "85638df95c4d3907d9dd686583f2e0b2bd4c232d36e025a5c48e91524b491c4b",
    description = "Fast C/C++ compiler cache",
    homepage = "https://ccache.dev/",
    license = "GPL-3+",
    configure_args = [
        "-DREDIS_STORAGE_BACKEND=OFF",  # Disable redis to avoid network fetch of hiredis
        "-DENABLE_DOCUMENTATION=OFF",
        "-DENABLE_TESTING=OFF",
        "-DDEP_BLAKE3=BUNDLED",  # Use bundled blake3 (no network for FetchContent)
        "-DDEP_XXHASH=SYSTEM",  # Use packaged deps instead of FetchContent download
        "-DDEP_FMT=SYSTEM",
    ],
    deps = [
        "//packages/linux/system/libs/compression/zstd:zstd",
        "//packages/linux/dev-libs/misc/xxhash:xxhash",
        "//packages/linux/dev-libs/misc/fmt:fmt",
    ],
    # ccache is in _TOOL_BLOCKLIST (prevents self-cycle), so cmake/ninja
    # aren't auto-injected — declare them explicitly.
    host_deps = [
        "//packages/linux/dev-tools/build-systems/cmake:cmake",
        "//packages/linux/dev-tools/build-systems/ninja:ninja",
    ],
)
