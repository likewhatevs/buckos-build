load("//defs:package.bzl", "package")

# dtl - Diff Template Library (header-only diff library in C++)

package(
    name = "dtl",
    build_rule = "binary",
    version = "1.21",
    url = "https://github.com/cubicdaiya/dtl/archive/refs/tags/v1.21.tar.gz",
    sha256 = "90ed2dbf4e6d687737fe25f118bbcb6aed778cecc3f2115d191a032bf8643dbd",
    description = "Diff Template Library - A header-only diff library written in C++",
    homepage = "https://github.com/cubicdaiya/dtl",
    license = "BSD",
    deps = [],
    install_script = """
        mkdir -p $OUT/usr/include/dtl
        cp -r dtl/*.hpp $OUT/usr/include/dtl/
    """,
)
