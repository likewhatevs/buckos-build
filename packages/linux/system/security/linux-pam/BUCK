load("//defs:package.bzl", "package")

# linux-pam - Pluggable Authentication Modules

package(
    build_rule = "autotools",
    name = "linux-pam",
    version = "1.6.1",
    source = "//packages/linux/system/security/auth/pam:pam-src",
    # Prevent aclocal re-generation (tarball has pre-generated files)
    pre_configure_cmds = ["find . -name '*.in' -o -name configure -o -name aclocal.m4 -o -name config.h.in | xargs touch"],
    description = "Pluggable Authentication Modules",
    homepage = "https://github.com/linux-pam/linux-pam",
    license = "BSD-3-Clause",
    configure_args = [
        "--enable-shared",
        "--disable-doc",
        "--disable-selinux",
        "--disable-audit",
        "--disable-regenerate-docu",
    ],
    deps = [
        "//packages/linux/system/libs/crypto/libxcrypt:libxcrypt",
    ],
)
