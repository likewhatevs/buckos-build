"""
Seed toolchain resolution.

Resolves the seed toolchain from one of four sources (highest priority first):

  1. buckos.source_mode = true  — force bootstrap, ignore any seed config
  2. buckos.seed_path           — local archive  (export_file at repo root)
  3. buckos.seed_url            — remote download (http_file)
  4. neither                    — bootstrap from source (stage 1 cross-compiler)

To force source build even if a seed is configured:

  [buckos]
  source_mode = true

To use a local prebuilt seed (drop seed-toolchain.zip at repo root):

  [buckos]
  seed_path = seed-toolchain.zip

To download a prebuilt seed:

  [buckos]
  seed_url = https://...
  seed_sha256 = abc123...

When a prebuilt seed is active, also declares //tc/seed:seed-archive-ref
as a stable alias to the archive target, used by tests.
"""

load(":defs.bzl", "seed_toolchain")

seed_toolchain()
