# Minimal test kernel config (tinyconfig base)
# Boots in both Cloud Hypervisor and QEMU with initramfs support.

# Boot
CONFIG_64BIT=y
CONFIG_MULTIUSER=y
CONFIG_PRINTK=y
CONFIG_BINFMT_ELF=y
CONFIG_BINFMT_SCRIPT=y
CONFIG_TTY=y

# Serial console (8250 for x86, PL011 for aarch64 Cloud Hypervisor)
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_SERIAL_EARLYCON=y
CONFIG_SERIAL_AMBA_PL011=y
CONFIG_SERIAL_AMBA_PL011_CONSOLE=y
CONFIG_SERIAL_OF_PLATFORM=y

# PCI (needed for virtio + ACPI power off)
CONFIG_PCI=y
CONFIG_PCI_MSI=y

# Block + virtio
CONFIG_BLOCK=y
CONFIG_VIRTIO_MENU=y
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_CONSOLE=y

# virtiofs (shared filesystem for VM tests)
CONFIG_FUSE_FS=y
CONFIG_VIRTIO_FS=y

# KVM guest + PVH boot (Cloud Hypervisor)
CONFIG_HYPERVISOR_GUEST=y
CONFIG_KVM_GUEST=y
CONFIG_PARAVIRT=y
CONFIG_PVH=y

# Initramfs
CONFIG_BLK_DEV_INITRD=y
CONFIG_RD_GZIP=y

# Pseudo-filesystems
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_TMPFS=y

# Ext4 (IMA disk images)
CONFIG_EXT4_FS=y
CONFIG_EXT4_FS_SECURITY=y

# ISO 9660 (QEMU ISO boot test)
CONFIG_ISO9660_FS=y
CONFIG_JOLIET=y

# Networking (loopback for init scripts)
CONFIG_NET=y
CONFIG_INET=y

# ACPI power off
CONFIG_ACPI=y
CONFIG_PM=y
